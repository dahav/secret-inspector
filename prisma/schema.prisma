generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  idPrefix  String
  nextId    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repos      Repo[]
  groups     Group[]
  sshKeys    SshKey[]
  scans      Scan[]
  findings   Finding[]
  idMappings IdMapping[]
}

model Repo {
  id        String   @id @default(cuid())
  projectId String
  url       String
  branch    String?
  name      String
  type      String   // "source" | "dist"

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  findings Finding[]

  @@unique([projectId, url])
}

model Group {
  id        String @id @default(cuid())
  projectId String
  name      String
  repoNames String // comma-separated

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SshKey {
  id         String   @id @default(cuid())
  name       String
  privateKey String   // encrypted
  projectId  String?
  createdAt  DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Scan {
  id           String    @id @default(cuid())
  projectId    String
  status       String    @default("pending") // pending|running|completed|error
  findingCount Int       @default(0)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  findings Finding[]
}

model Finding {
  id          String @id @default(cuid())
  projectId   String
  repoId      String
  scanId      String
  // Gitleaks data
  stableId    String
  ruleId      String
  description String
  match       String
  secret      String
  file        String
  startLine   Int
  commit      String
  fingerprint String
  // Enrichment
  distLocation   String @default("")
  distEnvVar     String @default("")
  codebaseLocation String @default("")
  codebaseEnvVar String @default("")
  gitShowLine    String @default("")
  gitShowEnvVar  String @default("")
  usageType      String @default("")
  isDuplicate    Boolean @default(false)
  // Assessment
  w               Int     @default(0)
  s               Int     @default(0)
  risiko          Int     @default(0)
  status          String  @default("found")
  ticketId        String  @default("")
  nachweis        String  @default("")
  remediationType String  @default("")
  bemerkung       String  @default("")
  falsePositive   Boolean @default(false)
  assessmentUpdatedAt DateTime?
  assessmentUpdatedBy String @default("")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repo    Repo    @relation(fields: [repoId], references: [id], onDelete: Cascade)
  scan    Scan    @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model IdMapping {
  id         String @id @default(cuid())
  projectId  String
  secretHash String
  stableId   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, secretHash])
}
